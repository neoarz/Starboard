# required
DISCORD_TOKEN=
BOT_ID=
POSTGRES_PASSWORD=

# Docker Compose database settings. SB_DATABASE_URL is optional when these are set.
POSTGRES_DB=starboard
POSTGRES_USER=starboard

SHARDS=1
DB_MAX_DB_CONNECTIONS=10
# true disables notifications
DEVELOPMENT=true

# optional
OWNER_IDS=

# Use this instead of POSTGRES_* when connecting to an existing database.
# SB_DATABASE_URL=postgresql://host.docker.internal/DB_NAME?user=DB_USER&password=DB_PASSWORD

PATREON_TOKEN=
SENTRY_URL=

MAIN_GUILD=
ERROR_CHANNEL_ID=
PATRON_ROLE=
SUPPORTER_ROLE=
PROXY=
